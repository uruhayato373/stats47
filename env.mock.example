# モック環境用の環境変数設定例
# このファイルをコピーして .env.mock として使用してください

# 環境設定
NEXT_PUBLIC_ENV=mock
NODE_ENV=development

# モックデータ設定
MOCK_DATA_PATH=data/mock

# 注意：mock環境ではデータベース接続は不要です。
# すべてのデータはローカルのJSONファイルから読み込まれます。
# 
# モック環境の特徴：
# - データソース: data/mock/database/*.json ファイル
# - 接続不要: データベース接続や API 接続が不要
# - 高速起動: ファイル読み込みのみで即座にデータ取得
# - オフライン開発: インターネット接続なしで開発可能
#
# 使用方法：
# 1. このファイルを .env.mock にコピー
# 2. npm run dev:mock で開発サーバーを起動
# 3. ブラウザで http://localhost:3000 にアクセス
