# ==============================================================================
# キャプション生成用の環境変数（apps/video）
# ==============================================================================
#
# このファイルをコピーして .env.local として使用してください。
# pnpm caption:all 実行時に dotenv で読み込まれます。
#
# 使用方法:
#   cp env.local.example .env.local
#   GOOGLE_GEMINI_API_KEY に Google AI Studio で発行した API キーを設定
#
# ==============================================================================

# Google Gemini API キー（キャプション生成に必須）
# 取得: https://aistudio.google.com/app/apikey
# 無料枠あり。超過時は HTTP 429 で拒否され課金されません。
GOOGLE_GEMINI_API_KEY=

# ------------------------------------------------------------------------------
# Google Earth Studio (GES) レンダリング用（pnpm ges:render 実行時）
# ------------------------------------------------------------------------------
# GES にログインする Google アカウント。パスワードはリポジトリにコミットしないでください。
# GOOGLE_EMAIL=
# GOOGLE_PASSWORD=
