{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx tsx scripts/validate-env.ts && next dev --port 3000",
    "build": "npm run prebuild && npx tsx scripts/validate-env.ts && npx cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "build:production": "npx tsx scripts/validate-env.ts && npx cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" NODE_ENV=production NEXT_PUBLIC_ENV=production next build",
    "lint": "next lint",
    "knip": "cd ../.. && npm run knip -- --workspace apps/web",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:stats-data": "vitest run --dir ../../packages/estat-api/src/stats-data/__tests__",
    "test:stats-data:save-outputs": "npx cross-env SAVE_TEST_OUTPUTS=true vitest run src/features/estat-api/stats-data",
    "test:stats-data:watch": "npx cross-env SAVE_TEST_OUTPUTS=true vitest watch src/features/estat-api/stats-data",
    "test:analyze": "npx tsx scripts/analyze-coverage.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:smoke": "npx tsx scripts/smoke-test.ts",
    "test:smoke:local": "npx tsx scripts/smoke-test.ts --base-url http://localhost:3000",
    "test:smoke:playwright": "playwright test --config playwright.smoke.config.ts",
    "type-check": "npx cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" tsc --noEmit --skipLibCheck",
    "generate:search-index": "npx tsx scripts/generate-search-index.ts",
    "prebuild": "npx tsx scripts/generate-search-index.ts",
    "workers:clean": "rimraf .next .open-next",
    "workers:prebuild": "npm run workers:clean",
    "workers:build": "npm run workers:prebuild && npx cross-env CLOUDFLARE_WORKERS=true npx tsx scripts/validate-env.ts && npx cross-env CLOUDFLARE_WORKERS=true opennextjs-cloudflare build --workers-runtime",
    "workers:preview": "opennextjs-cloudflare preview",
    "workers:deploy:production": "wrangler deploy --env production"
  },
  "dependencies": {
    "@playwright/test": "^1.58.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@stats47/ai-content": "*",
    "@stats47/area": "*",
    "@stats47/area-profile": "*",
    "@stats47/category": "*",
    "@stats47/components": "*",
    "@stats47/database": "*",
    "@stats47/gis": "*",
    "@stats47/logger": "*",
    "@stats47/ranking": "*",
    "@stats47/types": "*",
    "@stats47/utils": "*",
    "@stats47/visualization": "*",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/nodemailer": "^7.0.4",
    "@types/unist": "^3.0.3",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "katex": "^0.16.11",
    "lucide-react": "^0.542.0",
    "minisearch": "^7.2.0",
    "next": "15.1.7",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.1.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "topojson-client": "^3.1.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@aws-sdk/client-s3": "^3.958.0",
    "@cloudflare/workers-types": "^4.20250830.0",
    "@opennextjs/cloudflare": "^1.12.0",
    "@stats47/mock": "*",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/flexsearch": "^0.7.6",
    "@types/geojson": "^7946.0.16",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/jsdom": "^27.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mdx": "^2.0.13",
    "@types/node": "20.19.20",
    "@types/node-fetch": "^2.6.13",
    "@types/parse-json": "^4.0.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/topojson-client": "^3.1.5",
    "@types/webpack": "^5.28.5",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "css-loader": "^6.11.0",
    "detect-secrets": "^1.0.6",
    "eslint": "^9.20.0",
    "eslint-config-next": "^16.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.2.6",
    "msw": "^2.12.7",
    "pino-pretty": "^13.1.2",
    "playwright": "^1.55.0",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.0",
    "size-limit": "^11.2.0",
    "tailwindcss": "^3.4.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "webpack": "5.101.2",
    "esbuild": "^0.25.0",
    "ajv": "^8.17.1",
    "css-loader": "^7.1.2"
  },
  "size-limit": [
    {
      "path": ".next/static/chunks/*.js",
      "limit": "500 KB"
    },
    {
      "path": ".next/static/chunks/pages/*.js",
      "limit": "200 KB"
    }
  ],
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
