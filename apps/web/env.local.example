# ==============================================================================
# 開発環境用の環境変数設定例
# ==============================================================================
# 
# このファイルをコピーして .env.local として使用してください
# Next.jsは .env.local を自動的に読み込みます
#
# 使用方法:
#   cp env.local.example .env.local
#   その後、必要な値を実際の値に置き換えてください
#
# ==============================================================================

# ==============================================================================
# 必須設定（アプリケーション動作に必要）
# ==============================================================================

# ------------------------------------------------------------------------------
# ベースURL設定
# ------------------------------------------------------------------------------
# サイトのベースURLを設定します
# メタデータ、OGP画像、構造化データで使用されます
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# NextAuth v5設定（Auth.js）
# ------------------------------------------------------------------------------
# 認証システムのシークレットキー
# 生成方法: openssl rand -base64 32 または
#          node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=dFIWzT92Oi8MA+m55uQJ3mw9HfNUT94BK1nZBELtdFc=
AUTH_URL=http://localhost:3000

# ホスト信頼設定（オプション）
# Cloudflare Workers環境では、コード側で trustHost: true を設定しているため、
# この環境変数は通常不要です。
# 環境変数で制御したい場合は、以下のコメントを外して設定してください。
# AUTH_TRUST_HOST=true

# ------------------------------------------------------------------------------
# e-Stat API設定
# ------------------------------------------------------------------------------
# e-Stat APIのアプリケーションID
# 取得方法: https://www.e-stat.go.jp/api/api-info/api-key
NEXT_PUBLIC_ESTAT_APP_ID=59eb12e8a25751dfc27f2e48fcdfa8600b86655e

# ==============================================================================
# オプション設定（機能を有効にする場合のみ設定）
# ==============================================================================

# ------------------------------------------------------------------------------
# Google AdSense 設定（オプション）
# ------------------------------------------------------------------------------
# Google AdSenseのクライアントID（ca-pub-XXXXXXXXXXXXXXXX形式）
# NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT_ID=ca-pub-7995274743017484
#
# AdSenseを有効にするかどうかのフラグ（true/false）
# NEXT_PUBLIC_GOOGLE_ADSENSE_ENABLED=true

# ------------------------------------------------------------------------------
# Google Search Console 認証コード（オプション）
# ------------------------------------------------------------------------------
# Google Search Consoleのサイト認証コード
# 設定方法:
#   1. Google Search Consoleにアクセス
#   2. プロパティを追加
#   3. 「HTMLタグ」方式で認証コードを取得
#   4. 以下のコメントを外して値を設定
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_site_verification_code

# ------------------------------------------------------------------------------
# Google Analytics 4 設定（オプション）
# ------------------------------------------------------------------------------
# Google Analytics 4の測定ID（G-XXXXXXXXXX形式）
# 設定方法:
#   1. Google Analyticsにアクセス
#   2. プロパティを作成または既存のプロパティを選択
#   3. 「管理」→「データストリーム」→「ウェブ」を選択
#   4. 測定ID（G-XXXXXXXXXX形式）をコピー
#   5. 以下のコメントを外して値を設定
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-SEK87WZJXE
#
# 注意:
#   - 測定IDが設定されていない場合、GA4は無効化されます
#   - 開発環境では通常、本番環境とは異なる測定IDを使用することを推奨します

# ------------------------------------------------------------------------------
# R2設定（オプション）
# ------------------------------------------------------------------------------
# 注意: アプリケーションコードではR2バインディングを使用するため、
# R2 APIトークン（CLOUDFLARE_R2_ACCESS_KEY_ID, CLOUDFLARE_R2_SECRET_ACCESS_KEY）は不要です。
#
# 固定値（全環境共通）
CLOUDFLARE_ACCOUNT_ID=cc10e4d021f2b259238dc98dfeebe907
# R2公開URL（画像URL生成用。Geoshape TopoJSON の R2 取得時にもベース URL として利用）
R2_PUBLIC_URL=https://pub-367d2dbfb20a4b2186830fb28e4f3401.r2.dev
# Geoshape 用 R2 ベース URL（未設定の場合は R2_PUBLIC_URL を使用。都道府県: gis/geoshape/20230101/jp_pref.l.topojson 等）
# NEXT_PUBLIC_R2_GEOSHAPE_URL=https://storage.example.com/gis/geoshape
# R2バケット名（参考用 - アプリケーションコードでは使用されません）
CLOUDFLARE_R2_BUCKET_NAME=stats47


# ------------------------------------------------------------------------------
# Cloudflare API設定（オプション）
# ------------------------------------------------------------------------------
# Cloudflare APIトークン（Wrangler CLIやAPI操作で使用）
# 
CLOUDFLARE_API_TOKEN=bvZZLe9xFwfwjGZWYGl-6y65z4W9E8PmbUJrCAsi

# ------------------------------------------------------------------------------
# Cloudflare D1 データベースID設定（オプション）
# ------------------------------------------------------------------------------
# リモートD1データベースに接続する場合に設定
# ローカル開発環境では通常不要（ローカルD1を使用）
# ステージング環境や本番環境のデータベースに接続する場合のみ設定
CLOUDFLARE_D1_DATABASE_ID_STAGING=39f18714-83bf-423c-9956-dcc9e466affb
CLOUDFLARE_D1_DATABASE_ID_PRODUCTION=e6533698-d05a-475b-9f39-5558703feef7

# ------------------------------------------------------------------------------
# ローカルD1データベースパス設定（オプション）
# ------------------------------------------------------------------------------
# ローカル開発環境でデータベースファイルのパスを直接指定する場合に設定
# 設定すると、起動時のファイル探索処理をスキップして高速化されます
# 相対パスまたは絶対パスで指定可能（相対パスの場合はプロジェクトルートからのパス）
# 
# Static DB（ランキングデータ等）のパス
# LOCAL_D1_STATIC_PATH=../../local-d1/data/v3/d1/miniflare-D1DatabaseObject/xxxxx.sqlite
# 
# Dynamic DB（ユーザーデータ等）のパス
# LOCAL_D1_DYNAMIC_PATH=../../local-d1/data/v3/d1/miniflare-D1DatabaseObject/xxxxx.sqlite

# ------------------------------------------------------------------------------
# Google Drive API設定（オプション）
# ------------------------------------------------------------------------------
# Google Drive APIのService Account認証情報（JSON形式）
# 設定方法:
#   1. Google Cloud Consoleでプロジェクトを作成
#   2. Google Drive APIを有効化
#   3. Service Accountを作成
#   4. サービスアカウントキーをJSON形式でダウンロード
#   5. JSONの内容をそのまま環境変数に設定（改行を含む場合はエスケープが必要）
# 例: GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'
# GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Google Driveの保存先フォルダID（オプション）
# フォルダIDを指定しない場合は、ルートディレクトリに保存されます
# フォルダIDの取得方法:
#   1. Google Driveでフォルダを開く
#   2. URLからフォルダIDを取得（例: https://drive.google.com/drive/folders/1a2b3c4d5e6f7g8h9i0j）
# GOOGLE_DRIVE_FOLDER_ID=

# ------------------------------------------------------------------------------
# プロキシ設定（オプション）
# ------------------------------------------------------------------------------
# プロキシ経由で外部API（R2、e-Stat APIなど）にアクセスする場合に設定
# AWS SDKやHTTPクライアントが自動的にこれらの環境変数を読み込みます
HTTP_PROXY=http://202.221.175.116:3128
HTTPS_PROXY=http://202.221.175.116:3128
NO_PROXY=localhost,127.0.0.1
