# 本番環境用の環境変数設定例
# このファイルをコピーして .env.production として使用してください

# e-Stat API設定
ESTAT_API_BASE_URL=https://api.e-stat.go.jp/rest/3.0/app
ESTAT_API_KEY=${PROD_ESTAT_API_KEY}

# Cloudflare設定
CLOUDFLARE_D1_DATABASE_ID=${PROD_D1_DATABASE_ID}
CLOUDFLARE_R2_BUCKET=${PROD_R2_BUCKET}
CLOUDFLARE_ACCOUNT_ID=${CLOUDFLARE_ACCOUNT_ID}
CLOUDFLARE_API_TOKEN=${CLOUDFLARE_API_TOKEN}

# 環境設定
NEXT_PUBLIC_ENV=production
NEXT_PUBLIC_USE_MOCK=false
NODE_ENV=production
