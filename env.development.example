# 開発環境用の環境変数設定例
# このファイルをコピーして .env.development として使用してください

# e-Stat API設定
ESTAT_API_BASE_URL=https://api.e-stat.go.jp/rest/3.0/app
NEXT_PUBLIC_ESTAT_APP_ID=59eb12e8a25751dfc27f2e48fcdfa8600b86655e

# 環境設定
NEXT_PUBLIC_ENV=development
NODE_ENV=development

# モックデータ設定
MOCK_DATA_PATH=data/mock

# R2 S3互換API設定（ローカル開発環境でR2にアクセスする場合）
# CloudflareダッシュボードでR2トークンを作成し、以下の値を設定してください
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key
# CLOUDFLARE_R2_BUCKET_NAME=stats47-development

# 注意：開発環境ではローカルD1（SQLite）を使用するため、Cloudflare設定は不要です。
# ローカルD1の使用方法：
# npx wrangler d1 execute stats47 --local --file=./database/schemas/main.sql
# npm run dev でローカル開発サーバーを起動
