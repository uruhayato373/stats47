# 開発環境用の環境変数設定例
# このファイルをコピーして .env.development として使用してください

# NextAuth v5設定（Auth.js）
AUTH_SECRET=dFIWzT92Oi8MA+m55uQJ3mw9HfNUT94BK1nZBELtdFc=
AUTH_URL=http://localhost:3000

# e-Stat API設定
ESTAT_API_BASE_URL=https://api.e-stat.go.jp/rest/3.0/app
NEXT_PUBLIC_ESTAT_APP_ID=your_estat_app_id

# R2統合バケット設定（環境別・ドメイン別ディレクトリ管理）
# 開発環境: stats47-development
# バケット内のディレクトリ構造:
#   - area/prefectures.json
#   - area/cities.json
#   - estat-api/metainfo/
#   - gis/geoshape/
R2_PUBLIC_URL=https://pub-37952187bcd746d583acaf1ebf3e06eb.r2.dev

# R2 S3互換API設定（ローカル開発用）
# Cloudflare R2にS3互換API経由でアクセスするための設定
# 設定手順:
# 1. Cloudflareダッシュボードにログイン
# 2. R2 Object Storage → Manage R2 API tokens
# 3. Create API token をクリック
# 4. Token name: stats47-development
# 5. Permissions: Object Read & Write
# 6. Bucket: stats47-development
# 7. 作成後、Access Key ID と Secret Access Key を取得
# 8. Account ID はCloudflareダッシュボードの右上から確認可能
CLOUDFLARE_ACCOUNT_ID=cc10e4d021f2b259238dc98dfeebe907
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=stats47-development