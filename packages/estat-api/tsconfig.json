{
  "compilerOptions": {
    "target": "ES2018",
    "lib": ["esnext", "dom"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@stats47/logger": ["../logger/src"],
      "@stats47/database": ["../database/src"],
      "@stats47/database/*": ["../database/src/*"],
      "@stats47/area": ["../area/src"],
      "@stats47/area/*": ["../area/src/*"],
      "@stats47/r2-storage": ["../r2-storage/src"],
      "@stats47/r2-storage/*": ["../r2-storage/src/*"],
      "@stats47/types": ["../types/src"],
      "@stats47/types/*": ["../types/src/*"],
      "@stats47/mock": ["../mock/src"],
      "@stats47/mock/*": ["../mock/src/*"],
      "@/*": ["src/*"]
    },
    "rootDirs": [
      "src"
    ]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}