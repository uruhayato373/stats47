{
  "name": "@stats47/area-profile",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "require": "./src/server.ts"
    }
  },
  "scripts": {
    "batch": "tsx -r ../ranking/src/scripts/setup-cli.js src/scripts/run-batch.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@stats47/database": "*",
    "@stats47/ranking": "*",
    "@stats47/types": "*",
    "drizzle-orm": "^0.45.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
