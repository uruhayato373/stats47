{
  "name": "@stats47/ai-content",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "require": "./src/server.ts"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "ai:list": "tsx src/scripts/list-pending.ts",
    "ai:list:force": "tsx src/scripts/list-pending.ts --force"
  },
  "dependencies": {
    "@stats47/area": "*",
    "@stats47/database": "*",
    "@stats47/ranking": "*",
    "drizzle-orm": "^0.45.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
