{
  "name": "@stats47/visualization",
  "version": "1.0.0",
  "private": true,
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./d3": {
      "types": "./src/d3/index.ts",
      "import": "./src/d3/index.ts",
      "require": "./src/d3/index.ts"
    },
    "./d3/BarChart": "./src/d3/components/BarChart/index.ts",
    "./d3/BarChartRace": "./src/d3/components/BarChartRace/index.ts",
    "./d3/BoxplotChart": "./src/d3/components/BoxplotChart/index.ts",
    "./d3/CategoryHeatmap": "./src/d3/components/CategoryHeatmap/index.ts",
    "./d3/CityMapChart": "./src/d3/components/CityMapChart/index.ts",
    "./d3/ColumnChart": "./src/d3/components/ColumnChart/index.ts",
    "./d3/DivergingBarChart": "./src/d3/components/DivergingBarChart/index.ts",
    "./d3/DonutChart": "./src/d3/components/DonutChart/index.ts",
    "./d3/HorizontalDivergingBarChart": "./src/d3/components/HorizontalDivergingBarChart/index.ts",
    "./d3/LineChart": "./src/d3/components/LineChart/index.ts",
    "./d3/MixedChart": "./src/d3/components/MixedChart/index.ts",
    "./d3/PrefectureMapChart": "./src/d3/components/PrefectureMapChart/index.ts",
    "./d3/PyramidChart": "./src/d3/components/PyramidChart/index.ts",
    "./d3/RadarChart": "./src/d3/components/RadarChart/index.ts",
    "./d3/Scatterplot": "./src/d3/components/Scatterplot/index.ts",
    "./d3/StackedAreaChart": "./src/d3/components/StackedAreaChart/index.ts",
    "./d3/SunburstChart": "./src/d3/components/SunburstChart/index.ts",
    "./d3/TileGridMapChart": "./src/d3/components/TileGridMapChart/index.ts",
    "./d3/TreemapChart": "./src/d3/components/TreemapChart/index.ts",
    "./shared": {
      "types": "./src/shared/index.ts",
      "import": "./src/shared/index.ts",
      "require": "./src/shared/index.ts"
    },
    "./leaflet": {
      "types": "./src/leaflet/index.ts",
      "import": "./src/leaflet/index.ts",
      "require": "./src/leaflet/index.ts"
    },
    "./leaflet/constants": {
      "types": "./src/leaflet/constants/tile-providers.ts",
      "import": "./src/leaflet/constants/tile-providers.ts",
      "require": "./src/leaflet/constants/tile-providers.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./src/server/index.ts",
      "require": "./src/server/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@stats47/area": "*",
    "@stats47/components": "*",
    "@stats47/logger": "*",
    "@stats47/types": "*",
    "@stats47/utils": "*",
    "@types/d3": "^7.4.3",
    "@types/topojson-client": "^3.1.5",
    "d3": "^7.9.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.542.0",
    "react-leaflet": "^5.0.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "jsdom": "^27.4.0",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.33.5",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": ">=5.0.0"
  }
}
