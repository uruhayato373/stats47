  "dependencies": {
    "@stats47/area": "*",
    "@stats47/components": "*",
    "@stats47/logger": "*",
    "@stats47/types": "*",
    "@stats47/utils": "*",
    "@types/d3": "^7.4.3",
    "@types/topojson-client": "^3.1.5",
    "d3": "^7.9.0",
    "leaflet": "^1.9.4",
