{
  "compilerOptions": {
    "target": "ES2018",
    "lib": ["esnext", "dom"],
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "rootDirs": [
      "src",
      "../logger/src"
    ],
    "baseUrl": ".",
    "paths": {
      "@stats47/logger": ["../logger/src"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
