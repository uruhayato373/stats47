{
  "name": "@stats47/database",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "require": "./src/server.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts",
      "require": "./src/client.ts"
    },
    "./config": {
      "types": "./src/config/local-db-paths.ts",
      "import": "./src/config/local-db-paths.ts",
      "require": "./src/config/local-db-paths.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "import": "./src/schema/index.ts",
      "require": "./src/schema/index.ts"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "import": "./src/core/index.ts",
      "require": "./src/core/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "import": "./src/testing/index.ts",
      "require": "./src/testing/index.ts"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "studio": "drizzle-kit studio",
    "studio:local": "drizzle-kit studio --config=drizzle.config.local.ts",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "articles:sync-from-r2": "tsx scripts/sync-articles-from-r2.ts",
    "backup:d1": "tsx scripts/backup-d1-to-r2.ts",
    "pull:d1": "tsx scripts/pull-remote-d1.ts",
    "diff:d1": "tsx scripts/d1-diff-report.ts"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20250830.0",
    "@stats47/logger": "*",
    "@stats47/types": "*",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@cloudflare/vitest-pool-workers": "^0.5.33",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "20.19.20",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.8",
    "js-yaml": "^4.1.1",
    "miniflare": "^4.20260128.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  }
}
