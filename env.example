# e-Stat API設定
# https://www.e-stat.go.jp/api/ でアプリケーションIDを取得
NEXT_PUBLIC_ESTAT_APP_ID=59eb12e8a25751dfc27f2e48fcdfa8600b86655e

# JWT認証用のシークレットキー
# 32文字以上のランダムな文字列を設定
JWT_SECRET=your-super-secret-jwt-key-here

# Cloudflare D1 データベース設定（オプション）
# Cloudflare Workersを使用する場合のみ必要
CLOUDFLARE_API_TOKEN=MqM4K7AN0x2CB19RJ4dyuHic4zp91yi1NiYf9sTS
CLOUDFLARE_ACCOUNT_ID=cc10e4d021f2b259238dc98dfeebe907
CLOUDFLARE_D1_DATABASE_ID=e6533698-d05a-475b-9f39-5558703feef7

# エラー処理設定（オプション）
# 連続エラーがこの数に達した場合、処理を停止します
MAX_ERRORS=3

# Google Analytics（オプション）
# Google Analyticsを使用する場合のみ必要
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
