{
  "name": "test",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "echo 'Please use dev:api or dev:mock instead of dev' && exit 1",
    "dev:api": "cross-env NODE_ENV=development NEXT_PUBLIC_ENV=development next dev",
    "dev:mock": "cross-env NODE_ENV=development NEXT_PUBLIC_ENV=mock next dev --turbopack",
    "dev:staging": "cross-env NODE_ENV=production NEXT_PUBLIC_ENV=staging next dev --turbopack",
    "dev:production": "cross-env NODE_ENV=production NEXT_PUBLIC_ENV=production next dev --turbopack",
    "build": "next build",
    "build:staging": "cross-env NODE_ENV=production NEXT_PUBLIC_ENV=staging next build",
    "build:production": "cross-env NODE_ENV=production NEXT_PUBLIC_ENV=production next build",
    "start": "next start",
    "lint": "next lint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "debug:formatter": "tsx src/lib/estat-api/stats-data/__debug__/formatter-debug.ts",
    "debug:helpers": "tsx src/lib/estat-api/stats-data/__debug__/helpers-debug.ts",
    "debug:meta-info": "tsx src/lib/estat-api/meta-info/__debug__/formatter-debug.ts",
    "pre-deploy-check": "bash scripts/pre-deploy-check.sh",
    "deploy:dev": "bash scripts/deploy-dev.sh",
    "mock:download": "tsx scripts/download-mock-data.ts",
    "mock:validate": "tsx scripts/validate-mock-data.ts",
    "mock:size-check": "du -sh data/mock/ && find data/mock -name '*.json' | wc -l",
    "db:dump:local": "npx wrangler d1 execute stats47 --local --command '.dump' > database/backups/local_dump.sql",
    "db:dump:staging": "npx wrangler d1 execute stats47 --env staging --command '.dump' > database/backups/staging_dump.sql",
    "db:migrations:local": "npx wrangler d1 migrations apply stats47 --local",
    "db:migrations:staging": "npx wrangler d1 migrations apply stats47 --env staging",
    "db:migrations:production": "npx wrangler d1 migrations apply stats47 --env production"
  },
  "dependencies": {
    "@auth/d1-adapter": "^1.11.0",
    "@aws-sdk/client-s3": "^3.913.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "jotai": "^2.13.1",
    "lucide-react": "^0.542.0",
    "next": "15.5.2",
    "next-auth": "^5.0.0-beta.29",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.65.0",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "topojson-client": "^3.1.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@cloudflare/workers-types": "^4.20250830.0",
    "@eslint/eslintrc": "^3",
    "@storybook/addon-a11y": "^9.1.3",
    "@storybook/addon-docs": "^9.1.3",
    "@storybook/addon-onboarding": "^9.1.3",
    "@storybook/addon-vitest": "^9.1.3",
    "@storybook/nextjs-vite": "^9.1.3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.19.20",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "eslint-plugin-storybook": "^9.1.3",
    "jsdom": "^27.0.0",
    "markdownlint-cli": "^0.45.0",
    "playwright": "^1.55.0",
    "storybook": "^9.1.3",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "vite": "^7.1.9",
    "vitest": "^3.2.4",
    "wrangler": "^4.33.1"
  }
}
